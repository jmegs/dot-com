---
// Full-viewport generative "chroma" orb background, fixed behind page content.
// The avatar (see index.astro) dispatches "chroma:reroll" to shuffle the seed.
---

<canvas class="chroma-bg" aria-hidden="true"></canvas>
<canvas class="chroma-bg chroma-fade" aria-hidden="true"></canvas>

<style>
	.chroma-bg {
		position: fixed;
		top: calc(-1 * env(safe-area-inset-top, 0px));
		left: calc(-1 * env(safe-area-inset-left, 0px));
		width: calc(
			100vw + env(safe-area-inset-left, 0px) + env(safe-area-inset-right, 0px)
		);
		height: 100vh; /* fallback */
		height: calc(
			100lvh + env(safe-area-inset-top, 0px) + env(safe-area-inset-bottom, 0px)
		);
		z-index: -2;
		display: block;
	}
	/* Crossfade overlay: holds a snapshot of the outgoing composition. */
	.chroma-fade {
		opacity: 0;
		pointer-events: none;
	}
</style>

<script>
	import { createChromaRenderer, type Appearance } from "../lib/chroma";

	const CROSSFADE_MS = 700; // manual click — snappy feedback
	const AUTO_CROSSFADE_MS = 2500; // ambient drift — slow dissolve
	const AUTO_REROLL_MS = 10000; // time between ambient shuffles

	const canvas = document.querySelector<HTMLCanvasElement>("canvas.chroma-bg:not(.chroma-fade)")!;
	const ctx = canvas.getContext("2d")!;
	const fade = document.querySelector<HTMLCanvasElement>("canvas.chroma-fade")!;
	const fadeCtx = fade.getContext("2d")!;

	// Mutable identity — replaced on re-roll. Fresh random seed every page load.
	let renderer = createChromaRenderer(crypto.randomUUID());

	const darkMq = window.matchMedia("(prefers-color-scheme: dark)");
	const reduceMq = window.matchMedia("(prefers-reduced-motion: reduce)");

	function appearance(): Appearance {
		return darkMq.matches ? "dark" : "light";
	}

	// Match the page base + Safari theme-color to the current palette background.
	function syncTheme() {
		const bg = renderer.baseColor(appearance());
		document.documentElement.style.setProperty("--background", bg);
		document
			.querySelector('meta[name="theme-color"]')
			?.setAttribute("content", bg);
	}

	let width = 0;
	let height = 0;
	let rafId = 0;
	let startTime: number | null = null;

	function resize() {
		// Measure the canvas itself (sized to 100lvh in CSS) rather than the
		// window's *small* viewport, so the buffer covers the full screen
		// including behind iOS Safari's chrome.
		width = canvas.clientWidth;
		height = canvas.clientHeight;
		const dpr = Math.min(window.devicePixelRatio ?? 1, 2);
		canvas.width = Math.round(width * dpr);
		canvas.height = Math.round(height * dpr);
		ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
	}

	function renderFrame(time: number) {
		ctx.clearRect(0, 0, width, height);
		renderer.draw(ctx, width, height, time, appearance());
	}

	function stopLoop() {
		if (rafId) cancelAnimationFrame(rafId);
		rafId = 0;
		startTime = null;
	}

	function start() {
		stopLoop();
		resize();
		syncTheme();
		if (reduceMq.matches) {
			renderFrame(0);
			return;
		}
		const loop = (ts: number) => {
			if (startTime === null) startTime = ts;
			renderFrame((ts - startTime) / 1000);
			rafId = requestAnimationFrame(loop);
		};
		rafId = requestAnimationFrame(loop);
		scheduleAuto();
	}

	let fadeCleanup: ReturnType<typeof setTimeout> | undefined;

	function reroll(fadeMs = CROSSFADE_MS) {
		const next = createChromaRenderer(crypto.randomUUID());

		// Reduced motion: swap instantly, no crossfade.
		if (reduceMq.matches) {
			renderer = next;
			syncTheme();
			renderFrame(0);
			return;
		}

		// Snapshot the current frame into the overlay (1:1 device pixels).
		clearTimeout(fadeCleanup);
		fade.width = canvas.width;
		fade.height = canvas.height;
		fadeCtx.setTransform(1, 0, 0, 1, 0, 0);
		fadeCtx.clearRect(0, 0, fade.width, fade.height);
		fadeCtx.drawImage(canvas, 0, 0);
		fade.style.transition = "none";
		fade.style.opacity = "1";

		// Swap identity — the running rAF loop renders `next` from the next frame.
		renderer = next;
		syncTheme();

		// Dissolve the old snapshot to reveal the new composition underneath.
		requestAnimationFrame(() => {
			fade.style.transition = `opacity ${fadeMs}ms ease`;
			fade.style.opacity = "0";
		});
		fadeCleanup = setTimeout(() => {
			fadeCtx.clearRect(0, 0, fade.width, fade.height);
		}, fadeMs + 50);
	}

	// Ambient cadence: slowly crossfade to a new seed on a timer. Paused under
	// reduced motion and while the tab is hidden; reset on any manual re-roll.
	let autoTimer: ReturnType<typeof setTimeout> | undefined;
	function scheduleAuto() {
		clearTimeout(autoTimer);
		if (reduceMq.matches) return;
		autoTimer = setTimeout(() => {
			if (!document.hidden) reroll(AUTO_CROSSFADE_MS);
			scheduleAuto();
		}, AUTO_REROLL_MS);
	}

	let resizeTimer: ReturnType<typeof setTimeout>;
	window.addEventListener("resize", () => {
		clearTimeout(resizeTimer);
		resizeTimer = setTimeout(start, 150);
	});

	// Re-render when the OS theme or reduced-motion preference changes.
	darkMq.addEventListener("change", () => {
		syncTheme();
		if (reduceMq.matches || !rafId) renderFrame(0);
		// when animating, the rAF loop already reads the new appearance.
	});
	reduceMq.addEventListener("change", start);

	// Manual re-roll (avatar click): snappy crossfade, then reset the cadence so
	// an ambient shuffle doesn't fire right on the heels of an interaction.
	window.addEventListener("chroma:reroll", () => {
		reroll();
		scheduleAuto();
	});

	// Restart the cadence cleanly when returning to the tab.
	document.addEventListener("visibilitychange", () => {
		if (!document.hidden) scheduleAuto();
	});

	start();
</script>
